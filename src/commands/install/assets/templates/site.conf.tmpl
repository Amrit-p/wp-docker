{{/*
  Rendered into <prefix>/nginx/conf/<name>.conf for every site, whatever its type.
  nginx routes {{.ServerName}} here. For an apache-runtime site it proxies to the
  site's own container, which runs Apache and serves both static files and PHP.
  For an fpm-runtime site nginx serves the static files itself (they are the same
  mounted files the container sees at /var/www/html) and passes PHP over FastCGI
  to php-fpm on port 9000 in the container.
  Edit this and every site deployed from now on picks up the change.

    {{.Name}}        site name, e.g. blog
    {{.ServerName}}  the server_name value, e.g. blog.com www.blog.com
    {{.Upstream}}    the site's container, e.g. wpdock-blog
    {{.Prefix}}      the install prefix
    {{.FPM}}         true when the site runs php-fpm rather than apache
    {{.Root}}        the site's docroot on the host, mounted at /var/www/html
*/ -}}
# wpdock site: {{.Name}}

server {
    listen       80;
    server_name  {{.ServerName}};

    include {{.Prefix}}/nginx/conf.d/security.conf;

    # certbot's webroot challenges land in the shared webroot, so `wpdock ssl`
    # can prove the domain while the site is still plain http. `^~` wins over
    # the regex deny of dotfiles in security.conf.
    location ^~ /.well-known/acme-challenge/ {
        root  {{.Prefix}}/www;
    }
{{if .FPM}}
    root   {{.Root}};
    index  index.php;

    location / {
        try_files $uri $uri/ /index.php?$args;
    }

    # SCRIPT_FILENAME is the container's path (/var/www/html), not nginx's docroot,
    # because php-fpm opens the file itself. try_files keeps nginx from handing
    # off requests for php files that are not on disk.
    location ~ \.php$ {
        try_files               $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass            {{.Upstream}}:9000;
        fastcgi_index           index.php;
        include                 /etc/nginx/fastcgi_params;
        fastcgi_param           SCRIPT_FILENAME /var/www/html$fastcgi_script_name;
        fastcgi_param           PATH_INFO       $fastcgi_path_info;
    }
{{else}}
    location / {
        proxy_pass         http://{{.Upstream}};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
{{end}}}
