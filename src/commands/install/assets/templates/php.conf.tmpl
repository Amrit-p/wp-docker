{{/*
  Rendered by `wpdock deploy --stack=php` into <prefix>/nginx/conf/<name>.conf.
  Edit this and every site deployed from now on picks up the change.

    {{.Name}}        site name, e.g. shop
    {{.ServerName}}  the server_name value, e.g. shop.test
    {{.Root}}        the site's docroot, <prefix>/data/<name>
    {{.Prefix}}      the install prefix
    {{.PHP}}         what to hand .php to, e.g. unix:/run/php/php8.3-fpm.sock
*/ -}}
# wpdock site: {{.Name}} (php)

server {
    listen       80;
    server_name  {{.ServerName}};
    root         {{.Root}};
    index        index.php index.html;

    include {{.Prefix}}/nginx/conf.d/security.conf;

    # No front controller: a path either is a file or it is a 404.
    location / {
        try_files $uri $uri/ =404;
    }

    location ~ \.php$ {
        include {{.Prefix}}/nginx/conf.d/fastcgi.conf;
        fastcgi_pass {{.PHP}};
    }
}
